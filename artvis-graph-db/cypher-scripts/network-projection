// network projection artist co-exhibitions v1
CALL apoc.periodic.iterate(
    "
    MATCH (a1:Artist)-[:EXHIBITED]->(e:Exhibition)<-[:EXHIBITED]-(a2:Artist) WHERE id(a1) <> id(a2) RETURN a1,a2,e
    ",
    "MERGE (a1)<-[r:EXHIBITED_WITH]->(a2)
        ON CREATE SET r.exhibitions = [apoc.convert.toJson({ exhibitionId: e.id, startdate: e.startdate, enddate: e.enddate, title: e.title })]
        ON MATCH SET 
                r.exhibitions = CASE WHEN apoc.convert.toJson({ exhibitionId: e.id, startdate: e.startdate, enddate: e.enddate, title: e.title }) in r.exhibitions
                THEN r.exhibitions
                ELSE r.exhibitions + apoc.convert.toJson({ exhibitionId: e.id, startdate: e.startdate, enddate: e.enddate, title: e.title }) END
    ",
    { batchSize: 100000, parallel: false }
)


